<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
    <f:entry title="Job Name" field="jobName">
        <f:textbox autoCompleteDelimChar="" />
    </f:entry>
    <f:entry title="Display Name" field="displayName"
             description="Optional friendly name (defaults to job name).">
        <f:textbox />
    </f:entry>
    <f:entry title="Enabled" field="enabled">
        <f:checkbox default="true" />
    </f:entry>
    <f:entry>
        <div align="right">
            <f:repeatableDeleteButton />
        </div>
    </f:entry>
</j:jelly>
